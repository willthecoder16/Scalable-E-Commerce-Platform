# Copy to .env and adjust for local development
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_URL=amqp://ecommerce:ecommerce_secret@rabbitmq:5672

CONSUL_HOST=consul
CONSUL_PORT=8500

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=24h

# Payment Service — set MOCK=false and add keys for live mode
STRIPE_MOCK=true
STRIPE_SECRET_KEY=sk_test_...
PAYPAL_MOCK=true
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Notification Service — set MOCK=false and add keys for live mode
SENDGRID_MOCK=true
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=orders@yourdomain.com
TWILIO_MOCK=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

LOG_LEVEL=info

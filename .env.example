# Copy to .env and adjust for local development
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_URL=amqp://ecommerce:ecommerce_secret@rabbitmq:5672

CONSUL_HOST=consul
CONSUL_PORT=8500

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=24h

STRIPE_MOCK=true
SENDGRID_MOCK=true
TWILIO_MOCK=true

LOG_LEVEL=info
